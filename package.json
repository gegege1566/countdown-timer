{
  "name": "countdown-timer",
  "version": "1.0.2",
  "description": "Minimal always-on-top countdown timer for online presentations",
  "main": "main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --publish never",
    "build:dir": "electron-builder --win --dir"
  },
  "build": {
    "appId": "com.countdown-timer.app",
    "productName": "Countdown Timer",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "perMachine": false
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "build/icon.png"
    ]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  }
}
